#!/var/ossec/framework/python/bin/python3
import sys
import os
from socket import socket, AF_UNIX, SOCK_DGRAM
import json
import ipaddress
import re
import requests
from requests.exceptions import ConnectionError, Timeout, RequestException

# Wazuh queue socket
pwd = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
socket_addr = f"{pwd}/queue/sockets/queue"
LOG_FILE = "/var/ossec/logs/integrations.log"
CONFIG_FILE = os.path.join(os.path.dirname(os.path.realpath(__file__)), "custom-misp.conf")


def parse_bool(value, default=False):
    if value is None:
        return default

    normalized = str(value).strip().lower()
    if normalized in {"1", "true", "yes", "y", "on"}:
        return True
    if normalized in {"0", "false", "no", "n", "off"}:
        return False
    return default


def load_config(path=CONFIG_FILE):
    config = {}
    try:
        with open(path, "r", encoding="utf-8") as config_file:
            for line in config_file:
                line = line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                key, value = line.split("=", 1)
                config[key.strip()] = value.strip().strip('"').strip("'")
    except FileNotFoundError:
        pass
    return config


# MISP configuration
CONFIG = load_config()
MISP_BASE_URL = CONFIG.get("MISP_BASE_URL", os.getenv("MISP_BASE_URL", "https://{IP/Domain MISP}/attributes/restSearch/")).strip()
MISP_API_KEY = CONFIG.get("MISP_API_KEY", os.getenv("MISP_API_KEY", "API Key")).strip()
IGNORE_WARNINGLIST = parse_bool(CONFIG.get("IGNORE_WARNINGLIST", os.getenv("IGNORE_WARNINGLIST", "true")), default=True)

MISP_HEADERS = {
    "Content-Type": "application/json",
    "Authorization": MISP_API_KEY,
    "Accept": "application/json",
}


def get_nested(data, *keys):
    current = data
    for key in keys:
        if not isinstance(current, dict):
            return None
        current = current.get(key)
        if current is None:
            return None
    return current


def send_event(msg, agent=None):
    if not agent or agent.get("id") == "000":
        message = f"1:misp:{json.dumps(msg)}"
    else:
        agent_id = agent.get("id", "000")
        agent_name = agent.get("name", "unknown")
        agent_ip = agent.get("ip", "any")
        message = f"1:[{agent_id}] ({agent_name}) {agent_ip}->misp:{json.dumps(msg)}"

    with socket(AF_UNIX, SOCK_DGRAM) as sock:
        sock.connect(socket_addr)
        sock.send(message.encode())


def normalize_value(value):
    if not value:
        return None

    value = str(value).strip().lower()
    value = value.rstrip(".")

    value = re.sub(r"^https?://", "", value)
    value = value.split("/")[0]

    if ":" in value and not re.match(r"^[a-f0-9:]+$", value):
        value = value.split(":")[0]

    return value


def extract_event_param(alert):
    groups = alert.get("rule", {}).get("groups", []) or []
    group_set = {str(group).lower() for group in groups}

    regex_file_hash = re.compile(r"\b[A-Fa-f0-9]{64}\b")

    try:
        win_eventdata = get_nested(alert, "data", "win", "eventdata")
        linux_eventdata = get_nested(alert, "data", "eventdata")

        if isinstance(win_eventdata, dict):
            if group_set.intersection({
                "sysmon_event_1",
                "sysmon_event_6",
                "sysmon_event_7",
                "sysmon_event_15",
                "sysmon_event_23",
                "sysmon_event_24",
                "sysmon_event_25",
            }):
                hashes_str = get_nested(win_eventdata, "hashes") or get_nested(win_eventdata, "hash")
                if hashes_str:
                    match = regex_file_hash.search(str(hashes_str))
                    return match.group(0) if match else None

            if "sysmon_event_3" in group_set:
                is_ipv6 = str(get_nested(win_eventdata, "destinationIsIpv6") or "false").lower()
                dst_ip = get_nested(win_eventdata, "destinationIp")
                if dst_ip and is_ipv6 == "false" and ipaddress.ip_address(dst_ip).is_global:
                    return dst_ip
                return None

            if "sysmon_event_22" in group_set:
                query_name = get_nested(win_eventdata, "queryName")
                return normalize_value(query_name)

        if isinstance(linux_eventdata, dict):
            if "sysmon_event_3" in group_set:
                is_ipv6 = str(get_nested(linux_eventdata, "destinationIsIpv6") or "false").lower()
                dst_ip = get_nested(linux_eventdata, "DestinationIp") or get_nested(linux_eventdata, "destinationIp")
                if dst_ip and is_ipv6 == "false" and ipaddress.ip_address(dst_ip).is_global:
                    return dst_ip
                return None

        if "syscheck_entry_added" in group_set:
            return get_nested(alert, "syscheck", "sha256_after")

    except (ValueError, TypeError) as exc:
        log(f"extract failed rule_id={get_nested(alert, 'rule', 'id')} groups={groups} error={exc}")
        return None

    log(f"unsupported alert rule_id={get_nested(alert, 'rule', 'id')} groups={groups}")
    return None


def query_misp(value):
    payload = {
        "value": value,
        "to_ids": 1,
        "includeWarninglistHits": True,
    }

    try:
        response = requests.post(
            MISP_BASE_URL,
            headers=MISP_HEADERS,
            json=payload,
            verify=False,
            timeout=10,
        )

        if response.status_code >= 400:
            return {"error": f"MISP - Error connecting to API: HTTP {response.status_code}: {response.text[:500]}"}

        return response.json()

    except ConnectionError:
        return {"error": "Connection Error to MISP API"}
    except Timeout:
        return {"error": "Timeout calling MISP API"}
    except RequestException as e:
        return {"error": f"MISP API Request Error: {str(e)}"}
    except Exception as e:
        return {"error": f"Unknown Error: {str(e)}"}


def is_warninglist_hit(attribute):
    warnings = attribute.get("warnings", [])

    if warnings:
        return True

    return False


def handle_misp_response(misp_api_response, alert, alert_output):
    if "error" in misp_api_response:
        log(f"api error rule_id={get_nested(alert, 'rule', 'id')} error={misp_api_response['error']}")
        alert_output["misp"] = {}
        alert_output["integration"] = "misp"
        alert_output["misp"]["error"] = misp_api_response["error"]
        alert_output["misp"]["category"] = ""
        alert_output["misp"]["value"] = ""
        send_event(alert_output, alert.get("agent"))
        return

    attributes = misp_api_response.get("response", {}).get("Attribute", [])

    valid_attributes = []

    for attribute in attributes:
        if IGNORE_WARNINGLIST and is_warninglist_hit(attribute):
            continue

        valid_attributes.append(attribute)

    if valid_attributes:
        attribute = valid_attributes[0]

        alert_output["misp"] = {}
        alert_output["integration"] = "misp"
        alert_output["misp"]["source"] = {}
        alert_output["misp"]["event_id"] = attribute.get("event_id", "")
        alert_output["misp"]["category"] = attribute.get("category", "")
        alert_output["misp"]["value"] = attribute.get("value", "")
        alert_output["misp"]["type"] = attribute.get("type", "")
        alert_output["misp"]["source"]["description"] = alert.get("rule", {}).get("description", "")

        log(f"hit rule_id={get_nested(alert, 'rule', 'id')} category={alert_output['misp']['category']} value={alert_output['misp']['value']}")
        send_event(alert_output, alert.get("agent"))
    else:
        log(f"miss rule_id={get_nested(alert, 'rule', 'id')} attributes={len(attributes)}")


def main():
    if len(sys.argv) < 2:
        sys.exit("Usage: custom-misp.py <alert_file.json>")

    with open(sys.argv[1]) as f:
        alert = json.load(f)

    alert_output = {}

    wazuh_event_param = extract_event_param(alert)
    if not wazuh_event_param:
        log(f"skip no_ioc rule_id={get_nested(alert, 'rule', 'id')} groups={alert.get('rule', {}).get('groups', [])}")
        sys.exit(0)

    wazuh_event_param = normalize_value(wazuh_event_param)
    if not wazuh_event_param:
        log(f"skip normalize_empty rule_id={get_nested(alert, 'rule', 'id')}")
        sys.exit(0)

    log(f"query rule_id={get_nested(alert, 'rule', 'id')} value={wazuh_event_param}")
    misp_api_response = query_misp(wazuh_event_param)
    handle_misp_response(misp_api_response, alert, alert_output)


if __name__ == "__main__":
    main()